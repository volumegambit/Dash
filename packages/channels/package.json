{
  "name": "@dash/channels",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@dash/agent": "*",
    "@whiskeysockets/baileys": "^6.7.0",
    "grammy": "^1.31.0",
    "qrcode": "^1.5.4",
    "ws": "^8"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["esm"],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}

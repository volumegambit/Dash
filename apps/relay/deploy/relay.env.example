# Dash relay environment — copy to /etc/dash-relay/relay.env and fill in.
# Read by both the systemd unit (dash-relay.service) and the Caddyfile.
# Keep this file readable only by root: chmod 600 /etc/dash-relay/relay.env

# Apex zone the relay serves gateways under. With example.com, gateways are
# reachable at https://<gatewayId>.relay.example.com
RELAY_ZONE=example.com

# Local port the relay process listens on (Caddy proxies to it).
RELAY_PORT=8443

# Shared admission secret a gateway must present on dial-in. Generate a strong
# random value, e.g.  openssl rand -base64 32
# This MUST match the relay token configured in Mission Control.
RELAY_TOKEN=replace-with-a-strong-random-secret

# DNS provider API token for the ACME DNS-01 wildcard challenge. The variable
# name depends on your caddy-dns plugin; CF_API_TOKEN matches caddy-dns/cloudflare.
CF_API_TOKEN=replace-with-your-dns-provider-token

{
  "name": "@dash/gateway",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@dash/agent": "*",
    "@dash/channels": "*",
    "@dash/mcp": "*",
    "@dash/chat": "*",
    "@dash/logging": "*",
    "@dash/management": "*",
    "@dash/models": "*",
    "@hono/node-server": "^1",
    "@hono/node-ws": "^1",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.0",
    "hono": "^4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.19.0"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["esm"],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}

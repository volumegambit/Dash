# Env vars override config/credentials.json (useful for CI, Docker, or temporary overrides).
# If you prefer JSON config, copy config.example/credentials.json to config/credentials.json.

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
OPENAI_API_KEY=sk-...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ALLOWED_USERS=123456789

# Logging (overrides config/dash.json)
LOG_LEVEL=info

{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "include": ["apps/mission-control/src/renderer/src/routes/chat.tsx"],
      "linter": {
        "rules": {
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    },
    {
      "include": ["apps/mission-control/src/renderer/src/routes/messaging-apps/$id.tsx"],
      "linter": {
        "rules": {
          "suspicious": {
            "noArrayIndexKey": "off"
          }
        }
      }
    }
  ],
  "files": {
    "ignore": [
      "**/dist/**",
      "**/out/**",
      "**/node_modules/**",
      "data/**",
      "**/*.gen.ts",
      ".claude/worktrees/**",
      ".worktrees/**",
      "apps/website/.next/**"
    ]
  }
}
